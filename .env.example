# ─────────────────────────────────────────────
#  NFT Marketplace Frontend — Environment
#  Copy to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────

# ── Blockchain ──────────────────────────────────────────────────────────────
# Alchemy Sepolia RPC endpoint
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Deployed NftMarketplace contract address on Sepolia
# Copy from NFTMarketplace/deployments/sepolia/NftMarketplace.json after deploy
MARKETPLACE_ADDRESS=0xYOUR_CONTRACT_ADDRESS

# Sepolia chain ID — do not change
CHAIN_ID=YOUR_CHAIN_ID

# ── WalletConnect ────────────────────────────────────────────────────────────
# Create a project at https://cloud.walletconnect.com → copy Project ID
WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# ── The Graph ────────────────────────────────────────────────────────────────
# Your deployed subgraph query URL from Subgraph Studio
# Format: https://api.studio.thegraph.com/query/<id>/<name>/version/latest
SUBGRAPH_URL=https://api.studio.thegraph.com/query/YOUR_SUBGRAPH_URL

# ── IPFS / Pinata ────────────────────────────────────────────────────────────
# API keys from https://app.pinata.cloud/keys
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET=YOUR_PINATA_SECRET_KEY
PINATA_GATEWAY=https://gateway.pinata.cloud
